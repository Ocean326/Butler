#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BIN_DIR="${HOME}/.local/bin"
TARGET_PATH="${BIN_DIR}/butler-flow"
DESKTOP_TARGET_PATH="${BIN_DIR}/flow-desktop"
SOURCE_CLI="${ROOT_DIR}/tools/butler-flow"
SOURCE_DESKTOP="${ROOT_DIR}/tools/flow-desktop"
FORCE_INSTALL=0

for ARG in "$@"; do
  case "$ARG" in
    --force)
      FORCE_INSTALL=1
      ;;
    *)
      echo "unknown argument: ${ARG}" >&2
      echo "usage: ./tools/install-butler-flow [--force]" >&2
      exit 2
      ;;
  esac
done

mkdir -p "$BIN_DIR"

install_link() {
  local target_path="$1"
  local source_path="$2"
  local label="$3"

  if [[ -L "$target_path" ]]; then
    local current_target
    current_target="$(readlink "$target_path" || true)"
    if [[ "$current_target" == "$source_path" ]]; then
      echo "${label} already installed at ${target_path}"
      return 0
    fi
  fi

  if [[ -e "$target_path" || -L "$target_path" ]]; then
    if [[ "$FORCE_INSTALL" -ne 1 ]]; then
      echo "target already exists: ${target_path}" >&2
      echo "rerun with --force to replace it" >&2
      exit 1
    fi
    rm -f "$target_path"
  fi

  ln -s "$source_path" "$target_path"
  echo "installed ${label} -> ${target_path}"
}

install_link "$TARGET_PATH" "$SOURCE_CLI" "butler-flow"
install_link "$DESKTOP_TARGET_PATH" "$SOURCE_DESKTOP" "flow-desktop"
