{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "idea_loop decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "iteration",
    "decision",
    "summary"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "iteration": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "type": "string",
      "enum": ["PROCEED", "REFINE", "PIVOT", "STOP"]
    },
    "summary": {
      "type": "string"
    },
    "based_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_focus": {
      "type": "string"
    }
  }
}
