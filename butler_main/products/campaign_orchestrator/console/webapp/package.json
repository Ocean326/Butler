{
  "name": "butler-console-webapp",
  "version": "0.2.0",
  "description": "Butler Visual Console SPA build and test workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config spa/vite.config.ts",
    "build": "vite build --config spa/vite.config.ts",
    "preview": "vite preview --config spa/vite.config.ts",
    "test": "vitest run --config spa/vitest.config.ts",
    "test:watch": "vitest --config spa/vitest.config.ts",
    "typecheck": "tsc --project spa/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "@xyflow/react": "^12.3.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.3"
  }
}
