{
  "app_id": "cli_xxxxxxxx",
  "app_secret": "xxxxxxxx",
  "workspace_root": "..\\..",
  "agent_model": "auto",
  "cli_runtime": {
    "active": "cursor",
    "allow_runtime_override": true,
    "defaults": {
      "model": "auto",
      "profile": "",
      "speed": "",
      "config_overrides": [],
      "extra_args": []
    },
    "providers": {
      "cursor": {
        "type": "cursor",
        "enabled": true,
        "path": "",
        "known_models": [],
        "extra_args": []
      },
      "codex": {
        "type": "codex",
        "enabled": true,
        "path": "codex",
        "profile": "",
        "sandbox": "workspace-write",
        "ask_for_approval": "never",
        "skip_git_repo_check": true,
        "ephemeral": false,
        "search": false,
        "known_models": [],
        "config_overrides_map": {
          "speed": "model_reasoning_effort"
        },
        "extra_args": []
      }
    }
  },
  "model_aliases": {
    "fast": "auto",
    "quick": "auto"
  },
  "agent_timeout": 300,
  "max_reply_len": 4000,
  "_comment_cursor_cli": "可选 cursor_cli_path 指定 Cursor CLI 可执行文件路径；不设则自动解析 versions 下最新版本或 dist-package",
  "features": {
    "task_ledger": true,
    "memory_service": true,
    "governor": true,
    "legacy_heartbeat_markdown_mirrors": false
  },
  "logging": {
    "level": "info",
    "check_interval_seconds": 2,
    "timestamp": true
  },
  "startup_notify_open_id": "",
  "startup_notify_receive_id_type": "open_id",
  "tell_user_receive_id": "",
  "tell_user_receive_id_type": "open_id",
  "heartbeat": {
    "enabled": false,
    "app_id": "",
    "app_secret": "",
    "every_minutes": 5,
    "startup_delay_seconds": 300,
    "align_to_interval": false,
    "message": "管家bot 心跳正常",
    "receive_id": "",
    "receive_id_type": "open_id",
    "planner_model": "auto",
    "executor_model": "auto",
    "always_notify": true,
    "max_short_tasks": 8,
    "max_long_tasks_in_prompt": 8,
    "proactive_talk": {
      "enabled": true,
      "min_interval_seconds": 5400,
      "min_heartbeat_runs_since_last": 3,
      "min_completed_branches": 2,
      "max_chars": 220
    },
    "task_ledger_enabled": true,
    "heartbeat_stale_seconds": 600,
    "task_doc_token": "",
    "task_doc_folder_token": "",
    "_comment_task_doc": "可选：task_doc_token=已有云文档 token（推荐，在飞书里先建好文档把 token 填这里）；task_doc_folder_token=云空间目录 token 则首次会在该目录下创建文档。设后每轮 plan 将任务摘要同步到该云文档，见 agents/local_memory/飞书云文档发送与心跳任务云文档_方案.md"
  },
  "_comment_startup_notify": "open_id 须为本应用内获取，否则会报 open_id cross app",
  "_comment_startup_notify": "open_id 须为本应用获取，否则会报 open_id cross app；可改用 user_id + receive_id_type=user_id"
}
