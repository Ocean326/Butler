# Copy this file to `.env.codex.local` or another machine-local env file.
# Fill only the variables you actually use.

# Feishu skills / integrations
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# Codex / Cursor local execution
CURSOR_API_KEY=

# Upstream source skills
GITHUB_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=

# Optional runtime toggles
BUTLER_CHAT_FRONTDOOR_MODEL_ROUTER_ENABLED=
BUTLER_CHAT_FRONTDOOR_ROUTER_REVIEW_ENABLED=

# Optional Weixin bridge state
WEIXIN_STATE_DIR=
BUTLER_WEIXIN_STATE_DIR=
OPENCLAW_STATE_DIR=
